generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Branch {
  BranchID   String         @id @default(cuid())
  BranchName String
  Users      User[]
  Tickets    RepairTicket[]
}

model User {
  UserID     String          @id @default(uuid())
  Username   String          @unique
  Password   String          @default("1234") 
  Role       String          @default("User") 
  BranchID   String
  Branch     Branch          @relation(fields: [BranchID], references: [BranchID])
  Tickets    RepairTicket[]
  Comments   TicketComment[]
  CreatedAt  DateTime        @default(now())
}

model RepairTicket {
  TicketID      String          @id @default(cuid())
  UserID        String
  User          User            @relation(fields: [UserID], references: [UserID], onDelete: NoAction, onUpdate: NoAction)
  BranchID      String
  Branch        Branch          @relation(fields: [BranchID], references: [BranchID], onDelete: NoAction, onUpdate: NoAction)
  Product       String
  Symptom       String
  Description   String?
  ImageURL      String?
  Priority      String          @default("Medium")
  CurrentStatus String          @default("Planed")
  PlannedDate   DateTime?
  SLA_Deadline  DateTime?
  TotalCost     Float?
  CSAT_Score    Int?
  Technician    String?
  CreatedAt     DateTime        @default(now())
  History       TicketHistory[]
  Comments      TicketComment[]
}

model TicketHistory {
  HistoryID String       @id @default(cuid())
  TicketID  String
  Ticket    RepairTicket @relation(fields: [TicketID], references: [TicketID])
  Status    String
  UpdatedBy String
  Note      String?
  Timestamp DateTime     @default(now())
}

model TicketComment {
  CommentID String       @id @default(cuid())
  TicketID  String
  Ticket    RepairTicket @relation(fields: [TicketID], references: [TicketID], onDelete: NoAction, onUpdate: NoAction)
  UserID    String
  User      User         @relation(fields: [UserID], references: [UserID], onDelete: NoAction, onUpdate: NoAction)
  Message   String
  Timestamp DateTime     @default(now())
}
